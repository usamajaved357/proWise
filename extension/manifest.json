{
  "manifest_version": 3,
  "name": "PropWise — Upwork Proposal Writer",
  "version": "5.0.0",
  "description": "Write winning Upwork proposals in 10 seconds. One click while reading the job.",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": ["https://www.upwork.com/*"],
  "background": { "service_worker": "background/background.js" },
  "content_scripts": [{
    "matches": ["https://www.upwork.com/jobs/*", "https://www.upwork.com/ab/proposals/*"],
    "js": ["content/content.js"],
    "css": ["content/content.css"],
    "run_at": "document_idle"
  }],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "PropWise"
  },
  "icons": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" }
}
